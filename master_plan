graph = StateGraph(NexusState)
graph.add_node("dynamic_agent", dynamic_agent_node)
graph.add_node("evaluator_agent", evaluator_agent_node)
graph.add_node("task_decomposer", decompose_tasks_node)
graph.add_node("sub_agent_executor", execute_sub_agents_node)
graph.add_node("memory_manager", memory_manager_node)
graph.add_node("assembler", assemble_output_node)

graph.set_entry_point("dynamic_agent")
graph.add_edge("dynamic_agent", "evaluator_agent")
graph.add_conditional_edges("evaluator_agent", should_continue_debate,
    {"revise": "dynamic_agent", "approved": "task_decomposer"})
graph.add_edge("task_decomposer", "sub_agent_executor")
graph.add_edge("sub_agent_executor", "memory_manager")
graph.add_edge("memory_manager", "assembler")
graph.add_edge("assembler", END)
```

